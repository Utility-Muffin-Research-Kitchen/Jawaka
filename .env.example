# ScreenScraper.fr developer credentials.
# Copy this file to .env.local and replace the placeholder values.
# .env.local is git-ignored; never commit real credentials.

SCREENSCRAPER_DEV_ID=placeholder_dev_id
SCREENSCRAPER_DEV_PASSWORD=placeholder_dev_password

# Optional ScreenScraper developer debug password.
SCREENSCRAPER_DEBUG_PASSWORD=
